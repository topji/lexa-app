# PostgreSQL connection URL (required)
# For AWS RDS, use a pooled URL if available and optionally set DB_IDLE_TIMEOUT_MS (default 60000).
# DATABASE_URL=postgresql://user:pass@host:5432/dbname
DATABASE_URL=
# Optional: max idle time for a connection in ms before release (default 60000)
# DB_IDLE_TIMEOUT_MS=60000
# Optional: timeout when opening a new connection in ms (default 30000; increase if using VPN)
# DB_CONNECTION_TIMEOUT_MS=30000
CHAINLINK_API_KEY= edsfgergertgfertf
CHAINLINK_USER_SECRET=wrergf4werf4w
CHAINLINK_ENDPOINT=
CHAINLINK_WS_ENDPOINT=
# Target market slug (default: btc-updown-5m-1771880100)
MARKET_SLUG=btc-updown-5m-1771880100
API_PORT=3100
NEXT_PUBLIC_BACKEND_URL=http://localhost:3100
# Polygon RPC URL (optional). If set, used first; then public RPCs are tried as fallbacks for balance/allowance.
# POLYGON_RPC_URL=https://polygon-rpc.com
# Or use a free key from Alchemy/Infura for higher rate limits.
# JWT secret for auth tokens (generate with: openssl rand -hex 32)
JWT_SECRET=change_me_to_a_random_secret

# Runner: per-strategy entry cooldown = 1 min or until new market window (default 60000 ms)
# RUNNER_ENTRY_COOLDOWN_MS=60000

# Market insights for Polymarket 15m/1h (BTC, ETH, SOL) → synthdata_insights table.
# Default: Lexa-owned poller (Gamma + Binance spot) in the worker — no paid API.
# LEXA_MARKET_INSIGHTS_ENABLED=0   # set to disable
# LEXA_MARKET_INSIGHTS_POLL_INTERVAL_MS=30000
# BINANCE_SPOT_BASE=https://api.binance.us   # or https://api.binance.com if Binance US blocks you

# SynthData API (legacy alternative; only used if Lexa insights disabled AND key set)
# SYNTHDATA_ENABLED=0
# SYNTHDATA_API_URL=https://api.synthdata.co
# SYNTHDATA_API_KEY=your_api_key
# SYNTHDATA_POLL_INTERVAL_MS=30000

# Quant Backend (Python GARCH + Monte Carlo + Bayesian + Momentum signal engine)
# Set QUANT_BACKEND_ENABLED=1 to poll signals from quant-backend and feed into edge runner.
# Start the quant-backend first: cd quant-backend && source venv/bin/activate && python main.py
# QUANT_BACKEND_ENABLED=0
# QUANT_BACKEND_URL=http://localhost:8100
# QUANT_BACKEND_POLL_INTERVAL_MS=30000